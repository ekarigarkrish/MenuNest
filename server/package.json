{
  "name": "server",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "scripts": {
    "start": "cross-env NODE_ENV=prod node ./bin/www",
    "dev": "cross-env NODE_ENV=dev nodemon ./bin/www",
    "dev:client": "npm run dev --prefix ../client",
    "dev:server": "cross-env NODE_ENV=dev npm run dev",
    "dev:all": "concurrently \"npm run dev:client\" \"npm run dev:server\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "csrf-csrf": "^4.0.3",
    "debug": "~2.6.9",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "helmet": "^8.3.0",
    "morgan": "^1.10.1",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14"
  }
}
